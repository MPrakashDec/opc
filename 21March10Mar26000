import pandas as pd
import requests
from datetime import datetime
import pytz
from config import load_credentials
from dhan_rate_limit import throttle_dhan_data_api

IST = pytz.timezone("Asia/Kolkata")

def fetch_backtest_missing_leg():
    """
    Fetches the specific leg that failed in the Feb 26 backtest:
    Instrument: NIFTY 26000 CE
    Expiry: 10-MAR-2026
    Data Point: Feb 26, 12:45 IST
    """
    client_id, access_token = load_credentials()
    url = "https://api.dhan.co/v2/charts/rollingoption"
    
    # Using parameters from your successful newDhan1 script
    payload = {
        "underlyingSecurityId": "13", 
        "underlyingExchangeSegment": "NSE_IDX",
        "expiryCode": 1,              # 1 targets the 'Next' expiry
        "instrumentType": "OPTIDX",
        "optionType": "CALL",
        "strikePrice": 26000.0,
        "interval": "1",
        "fromDate": "2026-02-26",
        "toDate": "2026-02-26",
        "expiryFlag": "WEEK"          # 'WEEK' is used for the rolling historical API
    }

    headers = {
        "access-token": access_token,
        "Content-Type": "application/json",
    }

    print("Connecting to Dhan Rolling API...")
    throttle_dhan_data_api()
    
    try:
        resp = requests.post(url, json=payload, headers=headers, timeout=15)
        if resp.status_code != 200:
            print(f"Error: {resp.status_code} - {resp.text}")
            return

        data = resp.json().get("data", {})
        if not data or "start_Time" not in data:
            print("No data returned. The strike might be too far OTM or the API lacks history for this day.")
            return

        # Convert to DataFrame
        df = pd.DataFrame(data)
        df["timestamp"] = pd.to_datetime(df["start_Time"], unit="s").dt.tz_localize("UTC").dt.astimezone(IST)
        df.set_index("timestamp", inplace=True)

        # Target our specific backtest entry time
        target_start = IST.localize(datetime(2026, 2, 26, 12, 45))
        target_end = IST.localize(datetime(2026, 2, 26, 12, 50))
        
        snapshot = df.loc[target_start:target_end]

        if snapshot.empty:
            print(f"Data found for Feb 26, but no candles found between 12:45 and 12:50.")
            print("Available timestamps for this strike:")
            print(df.index[:5])
        else:
            print("\n--- NIFTY 10-MAR-26 26000 CE | Snapshot Feb 26 ---")
            print(snapshot[['open', 'high', 'low', 'close', 'volume']])
            
    except Exception as e:
        print(f"Connection failed: {e}")

if __name__ == "__main__":
    fetch_backtest_missing_leg()
    